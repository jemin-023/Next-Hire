# ┌─────────────────────────────────────────────────────────┐
# │  PocketAI Backend — Environment Configuration          │
# │  Edit these values, then restart the server:           │
# │    npm run dev                                         │
# │  Or hot-swap URLs at runtime via POST /api/config      │
# └─────────────────────────────────────────────────────────┘

PORT=5000

# ── PostgreSQL ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_interview
DB_USER=postgres
DB_PASSWORD=

# ── Kaggle Notebook URLs (localhost.run / ngrok) ────────
# These change every time you restart the Kaggle notebook.
# Paste the new URLs here and restart, or use POST /api/config
# to update them at runtime without restarting.

# Interview API — Qwen 2.5 14B (port 8003 on Kaggle)
INTERVIEW_API_URL=

# VLM Proctoring API — LLaVA-NeXT 7B (port 8000 on Kaggle)
VLM_PROCTORING_API_URL=

# CV Parser API — LLaMA 3.3 70B via Groq (port 8001 on Kaggle)
CV_PARSER_API_URL=

# AI Detector API — LLaMA 3.3 70B via Groq (port 8002 on Kaggle)
AI_DETECTOR_API_URL=

# ── Groq API Key (if needed by detector/parser) ────────
GROQ_API_KEY=
