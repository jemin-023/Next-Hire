# ── PocketAI Backend — Example .env ─────────────────────
# Copy this file to .env and fill in your values.

PORT=5000

# ── PostgreSQL ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_interview
DB_USER=postgres
DB_PASSWORD=

# ── Kaggle Notebook Tunnel URLs ─────────────────────────
# These change every time you restart a Kaggle notebook.
# You can either set them here or hot-swap via POST /api/config.

# Interview API — Qwen 2.5 14B (port 8003 on Kaggle)
INTERVIEW_API_URL=

# VLM Proctoring API — LLaVA-NeXT 7B (port 8000 on Kaggle)
VLM_PROCTORING_API_URL=

# CV Parser API — LLaMA 3.3 70B via Groq (port 8001 on Kaggle)
CV_PARSER_API_URL=

# AI Detector API — LLaMA 3.3 70B via Groq (port 8002 on Kaggle)
AI_DETECTOR_API_URL=

# ── Groq API Key (if needed by detector/parser) ────────
GROQ_API_KEY=
